{
  "name": "@bandeira-tech/b3nd-save",
  "version": "0.7.0",
  "description": "B3nd data-saving layer: Store backends (postgres, mongo, sqlite, fs, ipfs, s3, elasticsearch, localstorage, indexeddb, memory) and Store→ProtocolInterfaceNode clients.",
  "exports": {
    ".": "./src/mod.ts",
    "./clients": "./src/clients/mod.ts",
    "./errors": "./src/errors.ts",
    "./payload": "./src/payload.ts",
    "./read": "./src/read.ts",
    "./dispatch": "./src/dispatch.ts",
    "./memory": "./src/memory/mod.ts",
    "./postgres": "./src/postgres/mod.ts",
    "./mongo": "./src/mongo/mod.ts",
    "./sqlite": "./src/sqlite/mod.ts",
    "./fs": "./src/fs/mod.ts",
    "./ipfs": "./src/ipfs/mod.ts",
    "./s3": "./src/s3/mod.ts",
    "./elasticsearch": "./src/elasticsearch/mod.ts",
    "./localstorage": "./src/localstorage/mod.ts",
    "./indexeddb": "./src/indexeddb/mod.ts"
  },
  "tasks": {
    "test": "deno test --allow-all --ignore=src/postgres/integration.test.ts,src/mongo/integration.test.ts,src/sqlite/integration.test.ts,src/fs/integration.test.ts,src/ipfs/integration.test.ts,src/s3/integration.test.ts,src/elasticsearch/integration.test.ts,src/indexeddb/integration.test.ts,src/localstorage/integration.test.ts",
    "check": "deno check src/mod.ts src/clients/mod.ts src/errors.ts src/payload.ts src/read.ts src/dispatch.ts src/memory/mod.ts src/postgres/mod.ts src/mongo/mod.ts src/sqlite/mod.ts src/fs/mod.ts src/ipfs/mod.ts src/s3/mod.ts src/elasticsearch/mod.ts src/localstorage/mod.ts src/indexeddb/mod.ts",
    "test:integration:postgres": "deno test --allow-all src/postgres/integration.test.ts",
    "test:integration:mongo": "deno test --allow-all src/mongo/integration.test.ts",
    "test:integration:sqlite": "deno test --allow-all src/sqlite/integration.test.ts",
    "test:integration:fs": "deno test --allow-all src/fs/integration.test.ts",
    "test:integration:ipfs": "deno test --allow-all src/ipfs/integration.test.ts",
    "test:integration:s3": "deno test --allow-all src/s3/integration.test.ts",
    "test:integration:elasticsearch": "deno test --allow-all src/elasticsearch/integration.test.ts",
    "test:integration:indexeddb": "deno test --allow-all src/indexeddb/integration.test.ts",
    "test:integration:localstorage": "deno test --allow-all src/localstorage/integration.test.ts",
    "build:npm": "deno run -A scripts/build-npm.ts"
  },
  "imports": {
    "@bandeira-tech/b3nd-core": "jsr:@bandeira-tech/b3nd-core@^0.18.0",
    "@bandeira-tech/b3nd-core/types": "jsr:@bandeira-tech/b3nd-core@^0.18.0/types",
    "pg": "npm:pg@8",
    "mongodb": "npm:mongodb@6",
    "canonicalize": "npm:canonicalize@2.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/fs": "jsr:@std/fs@1",
    "@std/path": "jsr:@std/path@1",
    "@db/sqlite": "jsr:@db/sqlite@0.12",
    "fake-indexeddb": "npm:fake-indexeddb@5",
    "@astral/astral": "jsr:@astral/astral@^0.5.3",
    "@luca/esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@^0.11.1",
    "esbuild": "npm:esbuild@^0.24.0"
  },
  "lint": {
    "exclude": [],
    "rules": {
      "exclude": ["require-await", "no-import-prefix", "no-unversioned-import"]
    }
  },
  "compilerOptions": {
    "strict": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable",
      "deno.ns"
    ]
  },
  "publish": {
    "exclude": [
      "node_modules/",
      "dist/",
      ".env*",
      "*.test.ts",
      "*.js",
      "*.lock",
      "package.json",
      "package-lock.json",
      "tsup.config.ts",
      ".npmignore",
      "src/indexeddb/_browser/",
      "src/localstorage/_browser/",
      "tests/"
    ]
  }
}
