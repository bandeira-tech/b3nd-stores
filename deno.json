{
  "name": "@bandeira-tech/b3nd-save",
  "version": "0.6.0",
  "description": "B3nd data-saving layer: Store backends (postgres, mongo, sqlite, fs, ipfs, s3, elasticsearch, localstorage, indexeddb, memory), Store→ProtocolInterfaceNode clients, shared backend helpers, and a URL-based backend factory.",
  "exports": {
    ".": "./src/mod.ts",
    "./factory": "./src/factory/mod.ts",
    "./clients": "./src/clients/mod.ts",
    "./shared": "./src/shared/mod.ts",
    "./memory": "./src/backends/memory/mod.ts",
    "./postgres": "./src/backends/postgres/mod.ts",
    "./mongo": "./src/backends/mongo/mod.ts",
    "./sqlite": "./src/backends/sqlite/mod.ts",
    "./fs": "./src/backends/fs/mod.ts",
    "./ipfs": "./src/backends/ipfs/mod.ts",
    "./s3": "./src/backends/s3/mod.ts",
    "./elasticsearch": "./src/backends/elasticsearch/mod.ts",
    "./localstorage": "./src/backends/localstorage/mod.ts",
    "./indexeddb": "./src/backends/indexeddb/mod.ts"
  },
  "tasks": {
    "test": "deno test --allow-all --ignore=src/backends/postgres/integration.test.ts,src/backends/mongo/integration.test.ts,src/backends/sqlite/integration.test.ts,src/backends/fs/integration.test.ts,src/backends/ipfs/integration.test.ts,src/backends/s3/integration.test.ts,src/backends/elasticsearch/integration.test.ts,src/backends/indexeddb/integration.test.ts,src/backends/localstorage/integration.test.ts",
    "check": "deno check src/mod.ts src/factory/mod.ts src/clients/mod.ts src/shared/mod.ts src/backends/memory/mod.ts src/backends/postgres/mod.ts src/backends/mongo/mod.ts src/backends/sqlite/mod.ts src/backends/fs/mod.ts src/backends/ipfs/mod.ts src/backends/s3/mod.ts src/backends/elasticsearch/mod.ts src/backends/localstorage/mod.ts src/backends/indexeddb/mod.ts",
    "test:integration:postgres": "deno test --allow-all src/backends/postgres/integration.test.ts",
    "test:integration:mongo": "deno test --allow-all src/backends/mongo/integration.test.ts",
    "test:integration:sqlite": "deno test --allow-all src/backends/sqlite/integration.test.ts",
    "test:integration:fs": "deno test --allow-all src/backends/fs/integration.test.ts",
    "test:integration:ipfs": "deno test --allow-all src/backends/ipfs/integration.test.ts",
    "test:integration:s3": "deno test --allow-all src/backends/s3/integration.test.ts",
    "test:integration:elasticsearch": "deno test --allow-all src/backends/elasticsearch/integration.test.ts",
    "test:integration:indexeddb": "deno test --allow-all src/backends/indexeddb/integration.test.ts",
    "test:integration:localstorage": "deno test --allow-all src/backends/localstorage/integration.test.ts",
    "build:npm": "deno run -A scripts/build-npm.ts"
  },
  "imports": {
    "@bandeira-tech/b3nd-core": "jsr:@bandeira-tech/b3nd-core@^0.18.0",
    "@bandeira-tech/b3nd-core/types": "jsr:@bandeira-tech/b3nd-core@^0.18.0/types",
    "pg": "npm:pg@8",
    "mongodb": "npm:mongodb@6",
    "canonicalize": "npm:canonicalize@2.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/fs": "jsr:@std/fs@1",
    "@std/path": "jsr:@std/path@1",
    "@db/sqlite": "jsr:@db/sqlite@0.12",
    "fake-indexeddb": "npm:fake-indexeddb@5",
    "@astral/astral": "jsr:@astral/astral@^0.5.3",
    "@luca/esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@^0.11.1",
    "esbuild": "npm:esbuild@^0.24.0"
  },
  "lint": {
    "exclude": [],
    "rules": {
      "exclude": ["require-await", "no-import-prefix", "no-unversioned-import"]
    }
  },
  "compilerOptions": {
    "strict": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable",
      "deno.ns"
    ]
  },
  "publish": {
    "exclude": [
      "node_modules/",
      "dist/",
      ".env*",
      "*.test.ts",
      "*.js",
      "*.lock",
      "package.json",
      "package-lock.json",
      "tsup.config.ts",
      ".npmignore",
      "src/backends/indexeddb/_browser/",
      "src/backends/localstorage/_browser/",
      "tests/"
    ]
  }
}
